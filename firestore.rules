rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    match /settings/{documentId} {
      allow read: if documentId == "main" || isActiveAdmin();
      allow create, update, delete: if documentId == "main" && isActiveAdmin();
    }

    match /statistics/{documentId} {
      allow read, create, update, delete: if documentId == "main" && isActiveAdmin();
    }

    match /admins/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /advertisers/{userId} {
      allow get, update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.email is string
        && request.resource.data.storeName is string
        && request.resource.data.status == "active";
      allow list, delete: if isActiveAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if isActiveAdmin()
        || (isSignedIn() && resource.data.advertiserId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.advertiserId == request.auth.uid
        && request.resource.data.status == "قيد المراجعة"
        && request.resource.data.campaignName is string
        && request.resource.data.targetUrl is string
        && request.resource.data.imageUrl is string
        && request.resource.data.startTime is string
        && request.resource.data.endTime is string;

      allow update: if isActiveAdmin()
        || (
          isSignedIn()
          && resource.data.advertiserId == request.auth.uid
          && request.resource.data.advertiserId == request.auth.uid
          && request.resource.data.status in ["قيد المراجعة", "متوقف مؤقتاً"]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
        );

      allow delete: if isActiveAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read, update, delete: if isActiveAdmin();
      allow create: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
