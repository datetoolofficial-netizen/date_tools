rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    match /settings/{documentId} {
      allow read: if documentId == "main" || isActiveAdmin();
      allow create, update, delete: if documentId == "main" && isActiveAdmin();
    }

    match /statistics/{documentId} {
      allow read, create, update, delete: if documentId == "main" && isActiveAdmin();
    }

    match /admins/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
